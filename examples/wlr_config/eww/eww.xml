<!-- The main eww configuration file. This is where your widgets and how they appear on the screen and what they
contain are defined. -->

<eww>
  <includes>
    <file path="./eww-notif.xml"/>
    <file path="./eww-hub.xml"/>
    <file path="./eww-bar.xml"/>
  </includes>

  <windows>
    <window name="hub" stacking="fg">
      <geometry anchor="center right" x="0" y="0" width="25%" height="95%"/> <!--Specifies geometry-->
      <widget>
        <hub/> <!--This is the def we created earlier-->
      </widget>
    </window>
    <window name="bar-1" screen="0" stacking="bt" exclusive="true">
      <geometry anchor="top center" x="0" y="0" width="100%" height="35"/> <!--Specifies geometry-->
      <widget>
        <bar/> <!--This is the def we created earlier-->
      </widget>
    </window>
    <window name="bar" screen="1" stacking="bt" exclusive="true">
      <geometry anchor="top center" x="0" y="0" width="100%" height="35"/> <!--Specifies geometry-->
      <widget>
        <bar/> <!--This is the def we created earlier-->
      </widget>
    </window>
  </windows>
</eww>
