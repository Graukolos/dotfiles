<eww>
  <definitions>
    <def name="hub">
      <box orientation="v" space-evenly="false" spacing="20" valign="center" class="hub">
        <locale/>
        <seperator/>
        <media/>
        <seperator/>
        <status/>
        <seperator/>
        <volume_slider/>
        <view_padding/>
        <main_factor/>
        <layout/>
        <seperator/>
        <user/>
        <notification/>
        <power/>
      </box>
    </def>

    <def name="user">
      <box orientation="h" halign="center" valign="center" spacing="20" space-evenly="false" class="user">
        <button halign="center" onclick="~/.local/bin/eww close hub">
          <box width="160" class="profile"></box>
        </button>
        <user_info/>
      </box>
    </def>

    <def name="seperator">
       <scale halign="fill" class="seperator" active="false" value="1" max="1"/>
    </def>

    <def name="locale">
      <box height="100" orientation="v" space-evenly="false" valign="start" spacing="10" halign="center" class="locale">
        <button halign="fill" class="time" onclick="">{{time}}</button>
        <button halign="fill" class="date" onclick="">{{date}}</button>
      </box>
    </def>

    <def name="media">
      <box halign="center" width="200" spacing="20" orientation="h" space-evenly="false" class="media">
        <image halign="center" width="100" path="/home/bryan/.cache/ncmpcpp/{{album}}.png"/>
        <box spacing="5" orientation="v"  halign="center" space-evenly="true" class="media-cluster">
          <label text="{{mpris}}" limit-width="35"></label>
          <label class="mpris_position" text="{{mpris_position}}"></label>
          <mpd/>
        </box>
      </box>
    </def>

    <def name="status">
      <box orientation="v" spacing="15" valign="fill" class="status">
        <box orientation="h" space-evenly="false" spacing="25" halign="center">
          <label text=""></label>
          <scale width="300" class="ram" active="false" max="101" value="{{ram}}"/>
        </box>
        <box orientation="h" space-evenly="false" spacing="25" halign="center">
          <label text=""></label>
          <scale width="300" class="cpu" active="false" max="101" value="{{cpu}}"/>
        </box>
        <box orientation="h" space-evenly="false" spacing="25" halign="center">
          <label text=""></label>
          <scale width="300" class="gpu" active="false" max="101" value="{{gpu}}"/>
        </box>
      </box>
    </def>

    <def name="mpd">
      <box orientation="h" spacing="15" halign="center" class="media-button">
        <button width="40" onclick="mpc --host 127.0.0.1 --port 6002 prev">玲</button>
        <button width="40" onclick="mpc --host 127.0.0.1 --port 6002 toggle">懶</button>
        <button width="40" onclick="mpc --host 127.0.0.1 --port 6002 next">怜</button>
      </box>
    </def>

    <def name="shortcuts">
      <box orientation="v" spacing="10" valign="fill" class="">
        <links/>
      </box>
    </def>

    <!-- Control widgets -->
    <def name="volume_slider">
      <box class="indicator" orientation="h" space-evenly="false" spacing="25" halign="center">
        <label text=""></label>
        <scale width="250" valign="center" min="0" max="101" value="{{volume}}" onchange="pamixer --set-volume $(echo {} | sed 's/\..*//')"/>
      </box>
    </def>

    <def name="view_padding">
      <box class="indicator" orientation="h" space-evenly="false" spacing="25" halign="center">
        <label text=""></label>
        <scale width="250" valign="center" min="0" max="60" value="5" onchange="riverctl set-layout-value kile int view_padding $(fish -c 'math -s0 {}')"/>
      </box>
    </def>

    <def name="main_factor">
      <box class="indicator" orientation="h" space-evenly="false" spacing="25" halign="center">
        <label text=""></label>
        <scale width="250" valign="center" min="10" max="90" value="55" onchange="riverctl set-layout-value kile fixed main_factor $(fish -c 'math {}/100')"/>
      </box>
    </def>

    <def name="notification">
      <box class="volume" orientation="v" space-evenly="true" spacing="10" halign="center">
      </box>
    </def>

    <!-- Power widget -->
    <def name="power">
      <box orientation="h" width="300" 
        style="padding: 0px 20px 20px 20px;"
        spacing="10" class="power">
        <button onclick="~/.local/bin/eww close hub;swaylock"></button>
        <button onclick="systemctl suspend;~/.local/bin/eww close hub">鈴</button>
        <button onclick="loginctl terminate-user $USER;~/.local/bin/eww close hub"></button>
        <button onclick="systemctl poweroff">⏻</button>
      </box>
    </def>

    <def name="layout">
      <box orientation="h" halign="center" spacing="10" class="layout">
        <button onclick="riverctl set-layout-value kile string set_tag 'focused|{v:hh}'">
          <image height="35" path="/home/bryan/Pictures/layouts/vertical.svg"></image>
        </button>
        <button onclick="riverctl set-layout-value kile string set_tag 'focused|{h:vv}'">
          <image height="35" path="/home/bryan/Pictures/layouts/horizontal.svg"></image>
        </button>
        <button onclick="riverctl set-layout-value kile string set_tag 'focused|{d:ht{v:hh}}'">
          <image height="35" path="/home/bryan/Pictures/layouts/dwindle.svg"></image>
        </button>
        <button onclick="riverctl set-layout-value kile string set_tag 'focused|t'">
          <image height="35" path="/home/bryan/Pictures/layouts/tab.svg"></image>
        </button>
        <button
          style="font-size: 24px;"
          onclick="riverctl set-layout-value kile string clear_tag focused">
          
        </button>
      </box>
    </def>

    <!-- User info -->
    <def name="user_info">
      <box orientation="v" spacing="5" class="info">
        <box orientation="h" class="hostname" space-evenly="false" spacing="25" halign="start">
          <label text="{{hostname}}"></label>
        </box>
        <box orientation="h" space-evenly="false" spacing="25" halign="start">
          <label class="icon" text=""></label>
          <label text="{{uptime}}"></label>
        </box>
        <box orientation="h" space-evenly="false" spacing="25" halign="start">
          <label class="icon" text=""></label>
          <label text="{{disk_usage}} /run/media/bryan"></label>
        </box>
        <box orientation="h" space-evenly="false" spacing="15" halign="start">
          <label class="icon" text=""></label>
          <label text=" {{weather}}"></label>
        </box>
      </box>
    </def>

  </definitions>
  <variables>
    <script-var name="reserve_space">riverctl set-layout-value kile int xoffset -480</script-var>
    <script-var name="reset_space">riverctl set-layout-value kile int xoffset 0</script-var>
    <script-var name="hostname">echo $(hostname)@"$USER"</script-var>
    <script-var interval="10s" name="time">date "+%H:%M"</script-var>
    <script-var interval="10s" name="date">date "+%A, %b %d"</script-var>
    <script-var name="album">playerctl metadata --format '{{album}}' -F</script-var>

    <script-var interval="30m" name="weather">~/.config/waybar/scripts/weather.sh Terrebonne -s</script-var>
    <script-var interval="30m" name="weather_icon">curl -s 'https://wttr.in/?format=1' | sed 's/[+0-9a-cA-Z°-]//g' | grep -o . | head -1</script-var>

    <script-var interval="60s" name="uptime">~/.config/eww/scripts/time</script-var>
    <script-var name="disk_usage">df /run/media/bryan | awk '{print $5}' | tail -1</script-var>

    <script-var interval="5s" name="volume">pamixer --get-volume</script-var>
    <script-var name="mpris_position">playerctl metadata --format '{{duration(position)}} / {{duration(mpris:length)}}' -F</script-var>
    <script-var interval="10s" name="ram">printf "%.0f\n" $(free -m | grep Mem | awk '{print ($3/$2)*100}')</script-var>
    <script-var interval="10s" name="gpu">sensors | grep edge | grep -o '[0-9]*' | head -1</script-var>
    <script-var interval="10s" name="cpu">sensors | grep Tdie | grep -o '[0-9]*' | head -1</script-var>
  </variables>
</eww>
