### Variables
#
# Logo key. Use Mod1 for Alt and Mod4 for Super.
set $mod Mod1

# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l

# styles
set $theme /etc/sway/themes/Sweet-neon

# Your preferred terminal emulator
set $term alacritty

# Your preferred application launcher
set $menu bemenu-run

### Lockscreen configuration
#
set $locking swaylock --config $theme/swaylock

# shutdown command
set $shutdown wlogout