# Logo key. Use Mod1 for Alt and Mod4 for Super.
set $mod Mod4

### Input configuration
#
# You can get the names of your inputs by running: swaymsg -t get_inputs
# Read `man 5 sway-input` for more information about this section.
input type:keyboard {
		xkb_layout "gb,de"
		xkb_options "grp:win_space_toggle"
}
input type:pointer {
			accel_profile flat
}
input type:touchpad {
			dwt enabled
			tap enabled
			natural_scroll enabled
}

# output DP-1 res 2560x1440 pos 0 0
# output DP-2 res 2560x1440 pos 2560 0

# start gtkgreeter
# fixing gtk3 startup bug
exec {
	systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK
	exec hash dbus-update-activation-environment 2>/dev/null && dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK
}
exec "GTK_THEME=Nordic-darker gtkgreet -l -c sway; swaymsg exit"

# offer shutdown options
bindsym $mod+Shift+e exec wlogout --layout /etc/greetd/wlogout

## Action // Increase volume of Master ##
bindsym XF86AudioRaiseVolume exec amixer -q sset 'Master' 2%+

## Action // Decrease volume of Master ##
bindsym XF86AudioLowerVolume exec amixer -q sset 'Master' 2%-

## Action // Mute volume of Master ##
bindsym XF86AudioMute exec amixer -q sset 'Master' toggle

## Action // Increase brightness ##
bindsym XF86MonBrightnessUp exec light -A 2

## Action // Decrease brightness ##
bindsym XF86MonBrightnessDown exec light -U 2

# capture PowerOff key
bindsym XF86PowerOff exec wlogout --layout /etc/greetd/wlogout

